# --- Logto (self-hosted) ---
LOGTO_ENDPOINT=https://logto-rezonans.baha.tr
LOGTO_MGMT_RESOURCE=https://default.logto.app/api
LOGTO_M2M_CLIENT_ID=your-m2m-app-id
LOGTO_M2M_CLIENT_SECRET=your-m2m-app-secret

# --- Google Sign-In ---
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# --- Backend-issued session JWT ---
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me
JWT_EXPIRES_IN=2592000

# --- SMTP (password reset emails) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
MAIL_FROM=Schumann Rezonansı <noreply@example.com>

# --- n8n (workflow automation) ---
N8N_BASE_URL=https://n8n.example.com
N8N_API_KEY=your-n8n-api-key

# Shared secret n8n must send (X-Internal-Secret) to call /internal/kp-alert
INTERNAL_TRIGGER_SECRET=change-me

# --- Server ---
PORT=4000

# Dev: expose password-reset code in API response. Set false once email is live.
DEV_EXPOSE_RESET_CODE=false
